# Optional — URL of the Google Earth Engine tile proxy.
# Leave unset to run Sentinel without the raster overlay (the control hides
# itself; the product never crashes). Defaults to "/api/gee-tiles", which is the
# same-origin serverless function (api/gee-tiles.mjs) on Vercel — so on Vercel
# you normally don't need to set this at all.
#
# Only set this if the proxy runs on a DIFFERENT origin, e.g.:
# VITE_GEE_TILES_URL=https://your-app.vercel.app/api/gee-tiles
VITE_GEE_TILES_URL=
